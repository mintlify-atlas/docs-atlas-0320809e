  "keyFeatures": [
    "DNS threat event enrichment with AutoFocus Threat Intelligence",
    "IoT threat detection from honeypot intelligence",
    "GTP/SCTP event logging for service providers",
    "Elasticsearch-based threat data storage",
    "Kibana visualization dashboards",
    "Multi-threaded background event processing",
    "Malware tag classification with confidence scoring",
    "CLI for administration and data loading"
  ],
  "publicApiSurface": [
    "sfn start - Start SafeNetworking application",
    "sfn version - Display version information",
    "sfn admin - Administrative CLI for curating SFN",
    "sfn iot - CLI for getting IoT information",
    "sfn load - Load CSV file into Elasticsearch",
    "processDNS() - Process DNS threat events",
    "processIoT() - Process IoT threat events",
    "getDomainDoc() - Retrieve domain document from Elasticsearch",
    "assessTags() - Assess threat tags for confidence scoring",
    "DNSEventDoc - Elasticsearch document class for DNS events",
    "IoTEventDoc - Elasticsearch document class for IoT events"
  ]
